{
  "scripts": {
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "website/**/*.{ts,tsx,css}": [
      "npm --prefix \"website/\" run lint:fix"
    ],
    "functions/**/*.{js,ts}": [
      "npm --prefix \"functions/\" run lint:fix"
    ]
  }
}
